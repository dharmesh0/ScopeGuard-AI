PROJECT_NAME=ScopeGuard AI
APP_ENV=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=scopeguard
POSTGRES_USER=scopeguard
POSTGRES_PASSWORD=scopeguard
DATABASE_URL=postgresql+psycopg://scopeguard:scopeguard@postgres:5432/scopeguard

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scopeguard

LLM_PROVIDER=fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

SEARCH_PROVIDER=duckduckgo
SEARXNG_BASE_URL=
TAVILY_API_KEY=

SANDBOX_RUNNER_IMAGE=scopeguard-api:latest
SANDBOX_CPU_LIMIT=0.5
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_NETWORK=bridge
SANDBOX_TIMEOUT_SECONDS=90
DOCKER_HOST=

REPORTS_DIR=/app/storage/reports
LOG_LEVEL=INFO
DEFAULT_ADMIN_EMAIL=admin@scopeguard.local
DEFAULT_ADMIN_PASSWORD=ChangeThisNow123!
WEBSOCKET_POLL_INTERVAL_SECONDS=1

